# Resend (email delivery) — get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email where quote requests are sent
CONTACT_EMAIL=info@cintasadhesivaspersonalizadas.com.ar

# WhatsApp number (numbers only, with country code)
WHATSAPP_NUMBER=5491112345678
NEXT_PUBLIC_WHATSAPP_NUMBER=5491112345678

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://cintasadhesivaspersonalizadas.com.ar

# Conversion tracking — Google Apps Script webhook URL
# See TRACKING_SETUP.md for instructions
TRACKING_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
